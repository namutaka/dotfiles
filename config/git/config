[include]
    path = ~/.gitconfig.local

[core]
  quotepath = false
  editor = mvim -f
  #editor = vimr --wait --nvim
  pager = delta

[interactive]
    diffFilter = delta --color-only


# https://github.com/dandavison/delta
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    line-numbers = true
    side-by-side = true


[alias]
  co = checkout
  cof = !git branch | cut -c 3- | fzf --preview-window wrap --preview \"git log -n 1 --pretty=format:'%Cgreen%d %Creset%s' {}\" | xargs -n 1 git checkout
  br = branch -v
  ci = commit
  sw = switch
  st = status -bs
  last = log -1 HEAD
  ds = diff --stat
  ca = diff --cached
  cs = diff --cached --stat
  vimdiff = difftool -t macvimdiff
  df = !git --no-pager diff --word-diff
  re = remote -v
  mt = mergetool
  glog = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
  changelog = log --graph --topo-order --stat
  fp = log --first-parent
  new = !sh -c \"git checkout -b feature/$1\"
  pub = push -u origin HEAD

  gone = !git for-each-ref --format '%(upstream:track) %(refname:short)' | grep gone

  # あるコミットがマージされた箇所を調べる (https://stackoverflow.com/questions/8475448/find-merge-commit-which-include-a-specific-commit)
  find-merge = "!sh -c 'commit=$0 && branch=${1:-HEAD} && (git rev-list $commit..$branch --ancestry-path | cat -n; git rev-list $commit..$branch --first-parent | cat -n) | sort -k2 -s | uniq -f1 -d | sort -n | tail -1 | cut -f2'"
  show-merge = "!sh -c 'merge=$(git find-merge $0 $1) && [ -n \"$merge\" ] && git show $merge'"


[color]
  ui = auto

[gui]
  commitmsgwidth = 85

[commit]
  template = ~/.stCommitMsg

[grep]
  lineNumber = true

[rerere]
  enabled = true


[diff]
  algorithm = patience
  tool = macvimdiff

[difftool]
  prompt = false

[difftool "macvimdiff"]
  cmd = "mvimdiff \"$LOCAL\" \"$REMOTE\""

[difftool "vimrdiff"]
    cmd = vimr --wait --nvim -d "$LOCAL" "$REMOTE"

[difftool "sourcetree"]
  cmd = opendiff \"$LOCAL\" \"$REMOTE\"
  path =


[merge]
  tool = mvimdiff
  #tool = vimrdiff
  conflictstyle = diff3

[mergetool]
  prompt = false
  keepBackup = false

[mergetool "mvimdiff"]
  cmd = mvimdiff -f "$LOCAL" "$MERGED" "$REMOTE"

[mergetool "vimrdiff"]
  # https://www.grzegorowski.com/using-vim-or-neovim-nvim-as-a-git-mergetool
  #cmd = vimr --wait --nvim -c \"Gvdiffsplit! \" \"$MERGED\"
  cmd = vimr --wait --nvim -d "$LOCAL" "$MERGED" "$REMOTE"

[mergetool "sourcetree"]
  cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
  trustExitCode = true


[push]
  default = simple

[pull]
  ff = only

[fetch]
  recurseSubmodules = false
  prune = true

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[user]
  useConfigOnly = true
	email = you@example.com
	name = Your Name

[init]
  defaultBranch = main

[credential]
  helper =
  helper = /usr/local/share/gcm-core/git-credential-manager

